# Optional override for the Hermes state root.
# Defaults to ~/.hermes when unset.
HERMES_CONSOLE_HERMES_DIR=

# Optional override for a workspace/context root used to discover
# high-signal project files like AGENTS.md or other context docs.
HERMES_CONSOLE_WORKSPACE_DIR=

# Optional override for the Hermes CLI binary used for diagnostics.
# Defaults to "hermes" when unset.
HERMES_CONSOLE_HERMES_BIN=

# Optional override for the local API port.
# Defaults to 3940 when unset. The web dev proxy reads the same value.
PORT=

# Optional override for the host/interface the API binds to.
# Defaults to 127.0.0.1 (the local-first default — Hermes Console is
# intended to be loopback-only). Only set HOST=0.0.0.0 when running
# inside a container behind a reverse proxy you trust to gate access.
HOST=

# Optional URL path prefix the app is mounted under.
# Defaults to / (root). Set BASE_PATH=/console (or any prefix) to serve
# the app under a sub-path — useful when running behind a reverse proxy
# that already owns the root. The Vite frontend bakes this prefix into
# asset URLs at build time, so the value MUST match between the build
# environment and the runtime environment.
BASE_PATH=
