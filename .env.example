# Optional override for the Hermes state root.
# Defaults to ~/.hermes when unset.
HERMES_CONSOLE_HERMES_DIR=

# Optional override for a workspace/context root used to discover
# high-signal project files like AGENTS.md or other context docs.
HERMES_CONSOLE_WORKSPACE_DIR=

# Optional override for the Hermes CLI binary used for diagnostics.
# Defaults to "hermes" when unset.
HERMES_CONSOLE_HERMES_BIN=

# Optional override for the local API port.
# Defaults to 3940 when unset. The web dev proxy reads the same value.
PORT=
